# ─── API Base URL ─────────────────────────────────────────────────────────────
# Dev: omit this — Vite proxies /api to localhost:4000 automatically (see vite.config.ts).
# Production: set to your API origin, e.g. https://api.unityfund.io
# VITE_API_URL=https://api.unityfund.io

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for canonical links and OG metadata. Should match your deployment domain.
# VITE_APP_URL=https://unityfund.io
