# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://unityfund:unityfund_dev@localhost:5432/unityfund"

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="k8UobYk3APgOoxUnNL7VpuxzwTsH4LsXtydfjcHs8RH0YISBB4OMqJsaafG+U8fWETu"
JWT_EXPIRES_IN="15m"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ─── Email (nodemailer) ────────────────────────────────────────────────────────
# For dev: use Mailtrap or Ethereal (https://ethereal.email)
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER="your-ethereal-user"
SMTP_PASS="your-ethereal-pass"
EMAIL_FROM="UnityFund <noreply@unityfund.app>"

# ─── Nomba ─────────────────────────────────────────────────────────────────────
# Sandbox (TEST credentials): https://sandbox.nomba.com/v1
# Production (LIVE credentials): https://api.nomba.com/v1
NOMBA_API_BASE_URL="https://sandbox.nomba.com/v1"
NOMBA_ACCOUNT_ID="your-parent-account-id"
NOMBA_SUB_ACCOUNT_ID="your-sub-account-id"
NOMBA_CLIENT_ID="your-client-id"
NOMBA_PRIVATE_KEY="your-private-key"
NOMBA_WEBHOOK_SECRET="your-webhook-secret"

# ─── Invitation ────────────────────────────────────────────────────────────────
INVITATION_EXPIRES_HOURS=48
PASSWORD_RESET_EXPIRES_HOURS=1

# ─── App URL (for email links) ─────────────────────────────────────────────────
APP_URL="http://localhost:5173"
